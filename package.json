{
  "name": "amcore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modular personal productivity platform",
  "author": "Alexander Morozov <mail@alex-morozov.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-morozov84/AMCore.git"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@amcore/eslint-config": "workspace:*",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored",
      "eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@angular-devkit/core>picomatch": "4.0.4",
      "@nestjs/config>lodash": "4.17.24",
      "@swc/cli>minimatch": "9.0.9",
      "@typescript-eslint/typescript-estree>minimatch>brace-expansion": "5.0.6",
      "ajv>fast-uri": "3.1.2",
      "eslint-plugin-import>minimatch": "3.1.5",
      "eslint-plugin-jsx-a11y>minimatch": "3.1.5",
      "eslint-plugin-react>minimatch": "3.1.5",
      "fdir>picomatch": "4.0.4",
      "node-emoji>lodash": "4.17.24",
      "path-to-regexp": "8.4.2",
      "protobufjs": "7.5.6",
      "redis-info>lodash": "4.17.24",
      "rollup": "4.59.0",
      "tinyglobby>picomatch": "4.0.4",
      "tmp": "0.2.6",
      "vite": "7.3.2"
    }
  }
}
