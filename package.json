{
  "name": "amcore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-oriented NestJS application starter",
  "author": "Alexander Morozov <mail@alex-morozov.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-morozov84/AMCore.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@amcore/eslint-config": "workspace:*",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "apps/api/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter api exec eslint --fix --no-warn-ignored",
      "pnpm --filter api exec eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter web exec eslint --fix --no-warn-ignored",
      "pnpm --filter web exec eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "packages/shared/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter shared exec eslint --fix --no-warn-ignored",
      "pnpm --filter shared exec eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored",
      "eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
