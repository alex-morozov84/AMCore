# ===========================================
# AMCore Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===========================================
# Docker Compose (see docs/operations/deployment.md)
# ===========================================
# These COMPOSE_* vars configure the `docker compose` stack. They are decoupled
# from the app's DATABASE_URL / REDIS_URL below (which are for host `pnpm dev`),
# so a host DB/Redis URL can never poison the containerized stack.
#
# Which profiles to activate. The reference docker-compose.yml bundles Postgres +
# Redis behind the `local-infra` profile.
#   - local full stack:  COMPOSE_PROFILES=local-infra  (default below) → bundled
#     Postgres + Redis; `cp .env.example .env && docker compose up` just works.
#   - managed/VPS DB & Redis: set COMPOSE_PROFILES= (EMPTY) and the COMPOSE_*_URL
#     overrides below — bundled infra is then skipped.
# Forgetting to clear this in remote mode starts the local Postgres/Redis too.
COMPOSE_PROFILES=local-infra

# Point the Docker stack at a managed/VPS Postgres / Redis. Unset → bundled
# compose services (`postgres` / `redis`). Setting the host DATABASE_URL/REDIS_URL
# below does NOT affect the Docker stack — only these do.
# COMPOSE_DATABASE_URL="postgresql://user:pass@db-host:5432/amcore?sslmode=require"
# COMPOSE_REDIS_URL="rediss://user:pass@redis-host:6380"

# Optional: direct (non-pooled) DB URL used ONLY by the one-shot `migrate` step.
# Set this when app traffic goes through PgBouncer/transaction pooling — Prisma
# migrations need a direct connection. Unset → migrations use COMPOSE_DATABASE_URL.
# MIGRATION_DATABASE_URL="postgresql://user:pass@db-direct:5432/amcore?sslmode=require"

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Host `pnpm dev` connection (NOT the Docker stack — that uses COMPOSE_DATABASE_URL
# above). Remote server recommended for multi-device development.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/amcore_dev?schema=public"

# Example for a host pointing at the bundled compose Postgres (published on :5432):
# DATABASE_URL="postgresql://amcore:amcore@localhost:5432/amcore?schema=public"

# Database connection pool tuning (defaults shown)
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_MS=30000
DATABASE_CONNECT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_QUERY_TIMEOUT_MS=30000

# Readiness probe fails when the pg pool waiting queue exceeds this value.
# Hysteresis (how long the breach must persist before K8s pulls the pod)
# is configured in the readinessProbe `failureThreshold` × `periodSeconds`,
# not here (it is a Kubernetes readinessProbe concern, not an app env var).
DATABASE_POOL_WAITING_THRESHOLD=5

# Production note: DATABASE_URL must include sslmode=require or sslmode=verify-full
# Example: postgresql://user:pass@host:5432/db?sslmode=require

# ===========================================
# Logging
# ===========================================
# Request body size cap for request logs (bytes). Bodies above this size
# collapse to a marker with original size + top-level keys. Set to 0 to
# disable body content in logs entirely.
LOG_BODY_MAX_BYTES=4096

# Readiness disk usage threshold. 0.9 means "fail readiness above 90% used".
HEALTH_DISK_THRESHOLD_PERCENT=0.9

# Slow-query log threshold (ms). Defaults: 100 in dev, 500 in production.
# Override to tune for the deployment's workload profile.
# SLOW_QUERY_THRESHOLD_MS=500

# ===========================================
# Redis
# ===========================================
# Use rediss:// for a TLS / managed Redis (Upstash, ElastiCache, Redis Cloud);
# credentials and DB index are supported: rediss://user:pass@host:6380/0
# TLS is derived from the scheme — no separate flag.
REDIS_URL="redis://localhost:6379"

# Webhook verification (ADR-044). Secrets are opt-in by provider name:
# WEBHOOK_<PROVIDER>_SECRET, for example WEBHOOK_STRIPE_SECRET or
# WEBHOOK_GENERIC_SECRET. Replay dedupe TTL defaults to the timestamp tolerance.
# WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
# WEBHOOK_REPLAY_DEDUPE_TTL_SECONDS=300
# WEBHOOK_STRIPE_SECRET=""
# WEBHOOK_GENERIC_SECRET=""

# HTTP idempotency (ADR-043)
# IDEMPOTENCY_RETENTION_SECONDS=86400
# IDEMPOTENCY_LOCK_TTL_SECONDS=30
# IDEMPOTENCY_FAIL_MODE="open"
# IDEMPOTENCY_REDIS_TIMEOUT_MS=100

# Realtime notifications — SSE + Redis Pub/Sub fan-out (ADR-053).
# NAMESPACE composes into the channel so deployments sharing one Redis stay
# isolated; NODE_ENV alone cannot separate staging from production. REQUIRED to be
# distinct per environment when a Redis instance is shared. Web and worker must use
# the same value. Grammar: ^[a-z0-9:_-]{0,64}$.
# NOTIFICATIONS_REALTIME_NAMESPACE=""
# Heartbeat keeps idle proxies from closing the stream (< proxy read timeout).
# NOTIFICATIONS_REALTIME_HEARTBEAT_MS=20000
# Per-user concurrent SSE streams (429 over cap).
# NOTIFICATIONS_REALTIME_MAX_PER_USER=5
# Global per-process SSE streams (503 over cap). Keep below the process FD ulimit.
# NOTIFICATIONS_REALTIME_MAX_CONNECTIONS=10000
# Per-connection write queue before a slow consumer is disconnected.
# NOTIFICATIONS_REALTIME_QUEUE_DEPTH=16
# Hard stream lifetime cap; the stream also closes at the bearer token's expiry.
# NOTIFICATIONS_REALTIME_MAX_STREAM_LIFETIME_MS=3600000
# Bounds how long a publish may sit in the Redis offline queue.
# NOTIFICATIONS_REALTIME_PUBLISH_TIMEOUT_MS=1000
# Max concurrent unsettled publishes before new hints are dropped (best-effort).
# NOTIFICATIONS_REALTIME_MAX_INFLIGHT_PUBLISH=1000

# ===========================================
# Queue dashboard (Bull Board)
# ===========================================
# Mounts the Bull Board queue UI. Disabled in production unless set to "true";
# always mounted (but SUPER_ADMIN-protected) outside production.
#
# IMPORTANT: this gate is evaluated at process bootstrap, BEFORE the app loads
# this .env file via ConfigModule. Setting it here does NOT enable the
# dashboard in production — set it as a real process/shell environment variable
# (Docker/Kubernetes/systemd/CI). The .env file only affects local non-prod
# runs, where the dashboard is enabled regardless of this flag.
# ENABLE_BULL_BOARD="false"
#
# Read-only mode (ADR-047). Secure default "true": the dashboard hides write
# actions (retry / promote / clean / remove jobs). Set "false" only if operators
# need those actions. Same bootstrap-time evaluation caveat as ENABLE_BULL_BOARD.
# BULL_BOARD_READ_ONLY="true"

# ===========================================
# Authentication
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-characters"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
JWT_REFRESH_DAYS=7
# Step-up (OB-06b): destructive admin ops require the session to have been
# (re)authenticated within this many seconds. Refresh via POST /auth/step-up.
STEP_UP_MAX_AGE_SECONDS=600

# ===========================================
# Google OAuth
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# ===========================================
# Application
# ===========================================
NODE_ENV="development"
API_PORT=5002
CORS_ORIGIN="http://localhost:3002"

# Prometheus metrics endpoint (ADR-042). Scrape at /api/v1/metrics in real
# bootstrap (or /metrics in e2e/test apps without the global prefix). If this
# route is reachable through public ingress, set METRICS_AUTH_TOKEN or block it
# at ingress/network policy.
# METRICS_ENABLED=true
# METRICS_AUTH_TOKEN=""

# Process role (ADR-041): web = HTTP + enqueues; worker = BullMQ processors +
# cron (health + metrics HTTP); all = both. Default `all` suits host `pnpm dev` and
# single-process deploys. The reference docker-compose.yml sets it per service
# (api=web, worker=worker) — you don't set it here for that.
# PROCESS_ROLE=all

# BullMQ worker concurrency (jobs processed in parallel per worker). Default 1;
# tune from ~floor(cpu/2) for I/O-bound jobs. Read by the worker role.
# WORKER_CONCURRENCY=1

# ===========================================
# Email Service
# ===========================================
EMAIL_PROVIDER="mock"  # mock | resend
RESEND_API_KEY=""      # Get from: https://resend.com/api-keys
EMAIL_FROM="noreply@amcore.com"
SUPPORT_EMAIL="support@amcore.com"
FRONTEND_URL="http://localhost:3002"
PASSWORD_RESET_EXPIRY_MINUTES=15
EMAIL_VERIFICATION_EXPIRY_HOURS=48

# ===========================================
# Storage (cloud-agnostic file storage)
# ===========================================
# Driver: s3 | local | memory.
#   - Unset, the driver is derived from NODE_ENV: development -> local,
#     test -> memory, production -> s3.
#   - In production this means s3 config below is required (the app fails to
#     boot without it), so it never silently falls back to local disk.
#   - s3 works with AWS S3, Cloudflare R2, DigitalOcean Spaces, Yandex Object
#     Storage, and Backblaze B2.
# STORAGE_DRIVER=local

# --- S3-compatible config (required when STORAGE_DRIVER=s3) ---
# STORAGE_ENDPOINT — SDK endpoint. Leave empty for AWS; set for other providers.
#   Cloudflare R2:  https://<ACCOUNT_ID>.r2.cloudflarestorage.com   (STORAGE_REGION=auto)
#   DO Spaces:      https://nyc3.digitaloceanspaces.com
#   Yandex:         https://storage.yandexcloud.net                 (STORAGE_REGION=ru-central1)
#   Backblaze B2:   https://s3.us-west-004.backblazeb2.com          (STORAGE_REGION=us-west-004)
STORAGE_ENDPOINT=""
# Browser-facing endpoint for public/presigned URLs. Falls back to STORAGE_ENDPOINT.
STORAGE_PUBLIC_ENDPOINT=""
STORAGE_REGION="us-east-1"
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
# Virtual-hosted style works for all five target providers; override only for edge cases.
STORAGE_FORCE_PATH_STYLE="false"

# --- Local driver config (when STORAGE_DRIVER=local) ---
STORAGE_LOCAL_ROOT="./uploads"
# Optional. Enables getPublicUrl on the local driver, which returns
# "<this base>/<key>". MUST be an unauthenticated static/CDN route serving the
# driver's object bytes — mount it at "<STORAGE_LOCAL_ROOT>/objects", NOT at the
# root (the root also holds the private "meta/" sidecars). Never point it at the
# guarded app-mediated download route.
STORAGE_LOCAL_PUBLIC_BASE_URL=""

# --- Limits & signed-URL TTLs ---
STORAGE_MAX_FILE_SIZE=52428800          # 50 MB hard ceiling; per-route presets narrow this
STORAGE_SIGNED_URL_DEFAULT_TTL=3600     # seconds
STORAGE_SIGNED_URL_MAX_TTL=604800       # 7 days (SigV4 hard limit; values are clamped to this)

# --- Health (opt-in) ---
# Include storage in the readiness probe. Off by default — storage is not on the
# core request hot path. Forks that depend on storage flip this to true.
STORAGE_HEALTH_ENABLED="false"
# Key the health probe HEADs (need not exist — a 404 still proves connectivity).
# With object-scoped S3 credentials, set this to a key inside the allowed prefix
# (e.g. "avatars/.health") so the probe isn't a false 403.
STORAGE_HEALTH_PROBE_KEY="__storage_health_check__"

# ============================================
# Media processing (image derivatives)
# ============================================
# Decode-safety limits for image processing (sharp/libvips). Source bytes are
# capped before download; decoded dimensions/pixels are validated after metadata.
MEDIA_MAX_SOURCE_BYTES="5242880"
MEDIA_MAX_WIDTH="8000"
MEDIA_MAX_HEIGHT="8000"
MEDIA_MAX_PIXELS="40000000"
# Hard libvips decode guard (defense-in-depth). Must be <= MEDIA_MAX_PIXELS.
MEDIA_SHARP_LIMIT_INPUT_PIXELS="40000000"
# Tighter pixel cap for the synchronous avatar path. Must be <= MEDIA_MAX_PIXELS.
MEDIA_AVATAR_MAX_PIXELS="8000000"
# Cache-control for public avatar derivatives (keys are per-upload versioned).
MEDIA_AVATAR_CACHE_CONTROL="public, max-age=31536000, immutable"

# Frontend env: see apps/web/.env.example
