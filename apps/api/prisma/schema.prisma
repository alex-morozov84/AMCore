// ===========================================
// AMCore Database Schema
// ===========================================
// Main configuration file for Prisma
// Models are split into separate files by module

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["core", "notifications", "fitness", "finance", "subscriptions"]
}
