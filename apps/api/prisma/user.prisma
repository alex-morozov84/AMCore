// ===========================================
// Core Module: Users & Authentication
// ===========================================

// -----------------------------
// Enums
// -----------------------------

enum OAuthProvider {
  GOOGLE
  GITHUB
  APPLE
  TELEGRAM

  @@schema("core")
}

enum Theme {
  LIGHT
  DARK
  SYSTEM

  @@schema("core")
}

enum SystemRole {
  USER
  SUPER_ADMIN

  @@schema("core")
}

enum AuditActorType {
  USER
  API_KEY
  SYSTEM

  @@schema("core")
}

enum AuditTargetType {
  USER
  API_KEY
  ORG_INVITE
  ORGANIZATION
  SESSION
  CLEANUP

  @@schema("core")
}

enum AuditCategory {
  SECURITY
  BUSINESS

  @@schema("core")
}

// -----------------------------
// Models
// -----------------------------

model User {
  id               String  @id @default(cuid())
  email            String
  emailCanonical   String  @unique
  emailVerified    Boolean @default(false)
  passwordHash     String?
  name             String?
  avatarUrl        String?
  // Monotonic fence for avatar mutations: a conditional CAS update (only when the
  // stored value is older) makes a stale lock holder unable to publish over, or
  // sweep, a newer concurrent version. See ADR-049.
  avatarGeneration Int     @default(0)
  phone            String? @unique
  locale           String  @default("ru")
  timezone         String  @default("Europe/Moscow")

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // RBAC
  systemRole SystemRole @default(USER)

  // Relations
  accounts                OAuthAccount[]
  sessions                Session[]
  settings                UserSettings?
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  memberships             OrgMember[]
  apiKeys                 ApiKey[]
  invitesSent             OrgInvite[]              @relation("InvitesSent")
  invitesAccepted         OrgInvite[]              @relation("InvitesAccepted")
  invitesRevoked          OrgInvite[]              @relation("InvitesRevoked")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  @@map("users")
  @@schema("core")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
  @@schema("core")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  familyId         String
  refreshToken     String    @unique // Hashed
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  revocationReason String?
  // OB-06b / ADR-037: server-side recent-auth timestamp for step-up.
  // Nullable: pre-migration rows are NULL and fail closed on @RequireFreshAuth.
  // Set to now() at fresh authentication (login/register/OAuth); carried
  // forward (never renewed) on refresh rotation; bumped by POST /auth/step-up.
  lastAuthAt       DateTime?

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("sessions")
  @@schema("core")
}

model UserSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  theme                Theme   @default(SYSTEM)
  notificationsEnabled Boolean @default(true)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
  @@schema("core")
}

// -----------------------------
// Password Reset & Email Verification Tokens
// -----------------------------

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // SHA-256 hash of a 64-char hex token
  expiresAt DateTime // createdAt + 15 minutes
  used      Boolean   @default(false)
  usedAt    DateTime?

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
  @@schema("core")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // SHA-256 hash of a 64-char hex token
  expiresAt DateTime // createdAt + 48 hours
  used      Boolean   @default(false)
  usedAt    DateTime?

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance
  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
  @@schema("core")
}

// ===========================================
// API Keys
// ===========================================

model ApiKey {
  id             String    @id @default(cuid())
  name           String
  shortToken     String    @unique
  keyHash        String
  salt           String
  scopes         String[]  @default([])
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([expiresAt])
  @@map("api_keys")
  @@schema("core")
}

// ===========================================
// RBAC: Organizations, Roles & Permissions
// ===========================================

model Organization {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  aclVersion Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members       OrgMember[]
  roles         Role[]
  permissions   Permission[]
  apiKeys       ApiKey[]
  invites       OrgInvite[]
  notifications Notification[]

  @@map("organizations")
  @@schema("core")
}

model OrgMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles        MemberRole[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("org_members")
  @@schema("core")
}

model MemberRole {
  id       String @id @default(cuid())
  memberId String
  roleId   String

  member OrgMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
  @@map("member_roles")
  @@schema("core")
}

model Role {
  id             String  @id @default(cuid())
  name           String
  description    String?
  isSystem       Boolean @default(false) // system roles cannot be deleted
  organizationId String? // null = system template; non-null = org-specific

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  members      MemberRole[]
  invites      OrgInvite[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
  @@schema("core")
}

model Permission {
  id             String   @id @default(cuid())
  action         String // 'create' | 'read' | 'update' | 'delete' | 'manage'
  subject        String // 'Contact' | 'User' | 'Organization' | 'all'
  conditions     Json? // CASL conditions: { "assignedToId": "${user.id}" }
  fields         String[] @default([]) // field-level: [] = all fields
  inverted       Boolean  @default(false) // explicit DENY (use sparingly)
  organizationId String? // null = system permission

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles        RolePermission[]

  @@index([organizationId, subject, action])
  @@map("permissions")
  @@schema("core")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("core")
}

// ===========================================
// Organization Invites (OB-02)
// ===========================================
//
// Pending-invite model for org membership. Replaces the previous
// "user must already exist" flow, which leaked platform-wide
// registration state via 404 vs 201 status-code deltas.
//
// Identity is bound by canonical email at create time and
// re-verified at accept time against the authenticated caller's
// `emailCanonical`. The raw token lives only inside the email
// body; only `tokenHash` (SHA-256) is at rest.
//
// Uniqueness is enforced via a Postgres partial unique index
// (declared declaratively here via `@@unique(..., where: {...})`
// using the `partialIndexes` preview feature). The predicate
// covers any row that has not yet been terminally settled —
// `acceptedAt IS NULL AND revokedAt IS NULL` — so an expired
// pending row still counts as "active" for the constraint.
//
// Re-invite contract (Stage B implements, pinned here for
// invariant-clarity at the schema level):
//
//   - For (orgId, emailCanonical) with no row in the active
//     bucket, `createInvite` inserts a new row.
//   - For (orgId, emailCanonical) with an existing active row
//     (pending or expired-pending), `createInvite` rotates that
//     row in place — new `tokenHash`, refreshed `expiresAt`,
//     possibly updated `roleId`/`invitedById`. The audit
//     timestamp of the first attempt collapses; this is an
//     accepted trade-off for the simpler partial-unique scope
//     vs introducing an `expiredAt` column purely for audit
//     chronology.
//   - Accepted or revoked rows are outside the partial unique
//     scope and can coexist with a fresh active row for the
//     same pair, so legitimate re-invite after a terminal
//     settle is possible without overwriting history.
model OrgInvite {
  id               String    @id @default(cuid())
  organizationId   String
  emailCanonical   String
  email            String
  roleId           String?
  invitedById      String?
  tokenHash        String    @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  revokedById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  invitedBy      User?        @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedByUser User?        @relation("InvitesAccepted", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  revokedByUser  User?        @relation("InvitesRevoked", fields: [revokedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, emailCanonical], where: { acceptedAt: null, revokedAt: null })
  @@index([emailCanonical])
  @@index([expiresAt])
  @@index([organizationId, createdAt])
  @@map("org_invites")
  @@schema("core")
}

model AuditLog {
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  actorType      AuditActorType
  actorId        String?
  action         String
  targetType     AuditTargetType?
  targetId       String?
  organizationId String?
  requestId      String?
  ip             String?
  category       AuditCategory    @default(SECURITY)
  metadata       Json

  @@index([createdAt], type: Brin)
  @@index([createdAt, id])
  @@index([actorId])
  @@index([targetId])
  @@index([organizationId])
  @@map("audit_log")
  @@schema("core")
}
