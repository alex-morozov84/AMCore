    "jest": "^30.4.2",
    "jest-mock-extended": "4.0.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "7.3.5",
    "vitest": "^4.1.10"
  }
