{
  "name": "@amcore/api",
  "version": "0.0.1",
  "private": true,
  "description": "AMCore API Server",
  "license": "MIT",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nest start --watch",
    "build": "nest build -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:email": "vitest run",
    "test:email:watch": "vitest watch",
    "test:email:ui": "vitest --ui",
    "test:email:cov": "vitest run --coverage",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest-e2e.config.js --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "telegram:setup": "tsx src/cli/telegram-setup.ts"
  },
  "prisma": {
    "schema": "./prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.98",
    "@ai-sdk/openai-compatible": "^2.0.62",
    "@amcore/shared": "workspace:^",
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/lib-storage": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@bull-board/api": "^8.1.2",
    "@bull-board/express": "^8.1.2",
    "@bull-board/nestjs": "^8.1.2",
    "@casl/ability": "^6.8.1",
    "@casl/prisma": "^1.6.2",
    "@formatjs/intl": "^4.1.17",
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@redis/client": "^5.12.1",
    "ai": "^6.0.230",
    "argon2": "^0.44.0",
    "axios": "^1.18.1",
    "bullmq": "^5.80.6",
    "cache-manager": "^7.2.9",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "file-type": "^22.0.1",
    "helmet": "^8.3.0",
    "jose": "^6.2.3",
    "nestjs-cls": "^6.2.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.17.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
