  "devDependencies": {
    "@amcore/eslint-config": "workspace:*",
    "@amcore/typescript-config": "workspace:*",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/redis": "^12.0.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/supertest": "^7.2.1",
